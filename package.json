{
  "name": "mcp-plugin-kraken",
  "version": "0.1.0",
  "description": "Kraken exchange MCP plugin for mcp-orbit — trading, balances, grid planning",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "mcp-plugin-kraken": "./dist/index.js"
  },
  "scripts": {
    "build": "rm -rf dist && tsc",
    "start": "node dist/index.js",
    "start:stdio": "node dist/index.js --stdio",
    "start:http": "node dist/index.js --http",
    "dev": "tsc --watch"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/okahari/mcp-plugin-kraken.git"
  },
  "author": "okahari",
  "license": "MIT",
  "dependencies": {
    "better-sqlite3": "^12.6.2",
    "dotenv": "^17.2.3",
    "mcp-orbit": "^0.1.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.3.1",
    "typescript": "^5.1.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
